<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Shape section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/camera_shape"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/rg_shape"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rb_circle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/shape_circle"
                android:textSize="15sp"
                android:buttonTint="@color/primary"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/rb_square"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/shape_square"
                android:textSize="15sp"
                android:buttonTint="@color/primary"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/rb_rounded"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/shape_rounded"
                android:textSize="15sp"
                android:buttonTint="@color/primary"
                android:textColor="@color/text_primary" />

        </RadioGroup>

        <!-- Corner radius (tampil hanya saat bentuk Persegi Panjang dipilih) -->
        <LinearLayout
            android:id="@+id/ll_corner_radius"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/corner_radius"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tv_corner_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24dp"
                    android:textSize="14sp"
                    android:textColor="@color/primary" />

            </LinearLayout>

            <SeekBar
                android:id="@+id/seekbar_corner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />

        </LinearLayout>

        <!-- Size section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/camera_size"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_size_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="200dp"
                android:textSize="14sp"
                android:textColor="@color/primary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/size_small"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/seekbar_size"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/size_large"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Background Mode section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/background_mode"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/rg_bg_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rb_bg_off"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bg_mode_off"
                android:textSize="15sp"
                android:buttonTint="@color/primary"
                android:textColor="@color/text_primary"
                android:paddingStart="8dp"
                android:layout_marginBottom="4dp" />

            <RadioButton
                android:id="@+id/rb_bg_blur"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bg_mode_blur"
                android:textSize="15sp"
                android:buttonTint="@color/primary"
                android:textColor="@color/text_primary"
                android:paddingStart="8dp"
                android:layout_marginBottom="4dp" />

            <RadioButton
                android:id="@+id/rb_bg_replace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bg_mode_replace"
                android:textSize="15sp"
                android:buttonTint="@color/primary"
                android:textColor="@color/text_primary"
                android:paddingStart="8dp" />

        </RadioGroup>

        <!-- Gallery picker (shown only when Ganti Latar is selected) -->
        <Button
            android:id="@+id/btn_pick_bg"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/pick_background_image"
            android:backgroundTint="@color/accent"
            android:textColor="@color/black"
            android:visibility="gone"
            android:layout_marginBottom="12dp" />

        <!-- Background image thumbnail -->
        <ImageView
            android:id="@+id/iv_bg_preview"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:background="#22000000"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_bg_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bg_image_hint"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            android:layout_marginBottom="32dp" />

        <!-- Segmentation quality (tampil saat BG mode bukan Mati) -->
        <LinearLayout
            android:id="@+id/ll_seg_quality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/seg_quality_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/seg_quality_hint"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp" />

            <RadioGroup
                android:id="@+id/rg_seg_quality"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rb_seg_normal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/seg_quality_normal"
                    android:textSize="15sp"
                    android:buttonTint="@color/primary"
                    android:textColor="@color/text_primary" />

                <RadioButton
                    android:id="@+id/rb_seg_smooth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/seg_quality_smooth"
                    android:textSize="15sp"
                    android:buttonTint="@color/primary"
                    android:textColor="@color/text_primary" />

            </RadioGroup>
        </LinearLayout>

        <Button
            android:id="@+id/btn_apply"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/apply_settings"
            android:backgroundTint="@color/primary" />

    </LinearLayout>
</ScrollView>
